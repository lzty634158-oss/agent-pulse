{
  "name": "agent-traffic-light-monitor",
  "version": "0.2.1",
  "description": "A status light and alerting layer for Claude Code and AI coding agents.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agent-traffic-light-monitor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.*.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "cli",
    "developer-tools",
    "observability"
  ],
  "author": "Lison",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lzty634158-oss/agent-pulse.git"
  },
  "bugs": {
    "url": "https://github.com/lzty634158-oss/agent-pulse/issues"
  },
  "homepage": "https://github.com/lzty634158-oss/agent-pulse#readme",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.17.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "node-notifier": "^10.0.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-notifier": "^8.0.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
